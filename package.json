{
  "name": "paircode",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "bun server/run-services.mjs dev",
    "dev:web": "next dev",
    "dev:ws": "bun server/ws-server.mjs",
    "build": "next build",
    "start": "bun server/run-services.mjs start",
    "start:web": "next start",
    "start:ws": "bun server/ws-server.mjs",
    "db:generate": "bunx --bun prisma generate --config prisma.config.ts",
    "db:push": "bunx --bun prisma db push --config prisma.config.ts",
    "lint": "eslint",
    "test": "bun test"
  },
  "dependencies": {
    "@node-rs/argon2": "^2.0.2",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jose": "^6.2.2",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "pg": "^8.20.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "prisma": "^7.4.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
